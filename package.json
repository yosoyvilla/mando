{
  "name": "mando",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "prettier": "^3.9.4",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14"
}
